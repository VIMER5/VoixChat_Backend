{
  "name": "discovery",
  "version": "1.0.0",
  "description": "discovery",
  "license": "ISC",
  "author": "-=V.I.M.E.R=-",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env esbuild.config.js --watch",
    "build": "node --env-file=.env esbuild.config.js",
    "docker:build": "docker build -t discovery:1.0 .",
    "docker:run": "docker run -d --name discoveryService -p 50051:50051 --env-file .env discovery:1.0",
    "docker:save": "docker save discovery:1.0 -o discovery.tar",
    "docker:load": "docker load -i discovery.tar"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "esbuild": "^0.27.1",
    "grpc-tools": "^1.13.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
